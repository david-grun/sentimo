# Sentimo — environment variable template
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored; NEVER commit real credentials.

# Neon Postgres — use the *pooled* connection string from the Neon dashboard
DATABASE_URL=postgresql://user:password@your-project-pooler.region.aws.neon.tech/neondb?sslmode=require

# Google Gemini API key — from Google AI Studio (https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here

# Comma-separated CORS allowlist for the FastAPI backend
# Local dev: the Next.js dev server. Production: add your Vercel domain.
ALLOWED_ORIGINS=http://localhost:3000

# Optional shared secret for mutating endpoints (POST/DELETE). When set, those
# endpoints require an X-API-Key header with this value; leave empty to disable
# (local dev). Note: the frontend ships this key to the browser, so it deters
# drive-by curl abuse, not a determined attacker — real auth would need users.
# API_KEY=change-me

# Frontend (goes in the frontend's .env.local, and in Vercel's env settings in prod)
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_API_KEY=change-me   # must match API_KEY if the backend sets one
