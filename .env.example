# Sentimo — environment variable template
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored; NEVER commit real credentials.

# Neon Postgres — use the *pooled* connection string from the Neon dashboard
DATABASE_URL=postgresql://user:password@your-project-pooler.region.aws.neon.tech/neondb?sslmode=require

# Google Gemini API key — from Google AI Studio (https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key-here

# Comma-separated CORS allowlist for the FastAPI backend
# Local dev: the Next.js dev server. Production: add your Vercel domain.
ALLOWED_ORIGINS=http://localhost:3000

# Frontend (goes in the frontend's .env.local, and in Vercel's env settings in prod)
# NEXT_PUBLIC_API_URL=http://localhost:8000
